{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build -w web",
  "outputDirectory": "web/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "server/src/schema.sql"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
