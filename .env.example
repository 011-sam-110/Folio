# ---------------------------------------------------------------------------
# AI gateway (OpenAI-compatible).
#
# Local development: run freellmapi and point at it.
#   npm --prefix C:\Users\sampo\freellmapi\server run dev
#
# Production: this MUST be a publicly reachable URL. A localhost address works on
# your machine and is unreachable from a Vercel function, so every AI call on the
# deployed site fails at connect time rather than with anything descriptive.
# ---------------------------------------------------------------------------
FOLIO_AI_BASE_URL=http://localhost:3001/v1
FOLIO_AI_KEY=

# Comma-separated fallback chains. Never use 'auto', the router can pick dead providers.
FOLIO_AI_TEXT_MODELS=gemini-2.5-flash,llama-3.3-70b-versatile,mistral-medium-latest
FOLIO_AI_VISION_MODELS=gemini-2.5-flash,gemini-3.5-flash,gemini-2.5-flash-lite
FOLIO_AI_TIMEOUT_MS=90000

# ---------------------------------------------------------------------------
# Shared-pool limits.
#
# Every user without a personal key spends the same operator-funded free-tier
# budget, so both ceilings below are what stop one enthusiastic user (or one
# script) exhausting the month for everyone. A request must clear BOTH.
#
# The IP ceiling is deliberately about 10x the account one: a university or halls
# NAT can put hundreds of legitimate students behind a single address, and sizing
# these equally would lock out a whole campus once ten people had used the app.
# ---------------------------------------------------------------------------
FOLIO_AI_FREE_MONTHLY_USER=100
FOLIO_AI_FREE_MONTHLY_IP=1000

# Encrypts user-supplied API keys at rest (AES-256-GCM). Falls back to a value
# derived from SESSION_SECRET when unset, which is fine locally but means
# rotating SESSION_SECRET silently invalidates every stored key. Set it
# explicitly in production. Generate with: openssl rand -base64 32
FOLIO_AI_KEK=

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
FOLIO_PORT=4780

# Signs session cookies. Required in production, where the app refuses to boot
# without it. Generate with: openssl rand -base64 32
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Social sign-in (OAuth) — optional.
#
# Each provider turns on only when BOTH its id and secret are set; leave them blank
# to hide that provider's button entirely (the login/signup pages read
# GET /api/auth/providers and render nothing for what is not configured). Secrets are
# read from the environment only and must never be committed.
#
# Register these redirect (callback) URIs with each provider:
#   Production: https://unote-six.vercel.app/api/auth/oauth/google/callback
#               https://unote-six.vercel.app/api/auth/oauth/github/callback
#   Local dev:  http://localhost:5173/api/auth/oauth/google/callback
#               http://localhost:5173/api/auth/oauth/github/callback
#   (adjust the host to match OAUTH_BASE_URL below).
#
# Google:  console.cloud.google.com -> APIs & Services -> Credentials -> OAuth client ID
# GitHub:  github.com/settings/developers -> New OAuth App
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Public origin used to build the OAuth redirect_uri. Leave blank in production (the
# Vercel production hostname is used automatically). For local dev set it to the origin
# your browser loads — the Vite dev server — so the callback round-trips through it:
#   OAUTH_BASE_URL=http://localhost:5173
OAUTH_BASE_URL=
